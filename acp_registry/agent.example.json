{
  "$schema": "./agent-template-full.json",
  "name": "openclawd-agent",
  "display_name": "OpenClawd Agent",
  "description": "OpenClawd AI agent template — registered via ACP protocol 8004 with x402 payments, MCP tools, and ClawdRouter integration",
  "ecosystem": "OpenClawd",
  "icon": "icon.svg",
  "distribution": {
    "type": "command",
    "command": "solana-clawd",
    "args": ["agent", "run"]
  },
  "services": [
    {
      "type": "mcp",
      "description": "Model Context Protocol server for tool execution and agent communication"
    },
    {
      "type": "a2a",
      "description": "Agent-to-Agent protocol for inter-agent communication and task delegation"
    }
  ],
  "registry": {
    "protocol": "8004",
    "program_id": "Ag8004rWo8ao8AUKhLk78iv2nLQpZMyBPXiAh5QLbFiE",
    "atom_program_id": "AToM1cZNgm8v9PqGi18J2CJvna3YiJzLAx2wLdGVpump",
    "metadata_storage": "ipfs",
    "clusters": ["mainnet-beta", "devnet"],
    "features": {
      "atom_reputation": true,
      "seal_v1": true,
      "x402_payments": true,
      "proof_pass": true,
      "heartbeat_sync": true
    }
  },
  "capabilities": {
    "skills": [
      "clawdhub",
      "solana-clawd"
    ],
    "domains": [
      "ai",
      "solana"
    ],
    "x402_support": true
  },
  "integration": {
    "clawd_router": true,
    "api_registrar": true,
    "acp_registry": true
  }
}
