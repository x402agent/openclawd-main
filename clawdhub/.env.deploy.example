# ── Convex backend ─────────────────────────────────────────────────────────────
# Required for Convex production deploy
CONVEX_DEPLOY_KEY=prod:frugal-caribou-165|eyJ2MiI6IjZhMzY3ZDE1YjhlNzQ1OTk5ZjlkNTQ2MDU1NTQ1ZmY0In0=
# e.g. https://knowing-crane-255.convex.site
CONVEX_SITE_URL=https://frugal-caribou-165.convex.cloud

# ── Web build/runtime wiring ────────────────────────────────────────────────────
# e.g. https://knowing-crane-255.convex.cloud
VITE_CONVEX_URL=https://frugal-caribou-165.convex.cloud
# Same as CONVEX_SITE_URL
VITE_CONVEX_SITE_URL=https://frugal-caribou-165.convex.cloud
# Production URL of this app — set to Railway domain or custom domain
# e.g. https://nanohub-web-production.up.railway.app
SITE_URL=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# ── Railway runtime ─────────────────────────────────────────────────────────────
# Nitro preset — must be node-server for Railway
NITRO_PRESET=node-server
# PORT is injected automatically by Railway; set here only for local testing
# PORT=3000

# ── Optional Supabase event mirroring ──────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_EVENTS_TABLE=skill_events

# ── Solana Data APIs ─────────────────────────────────────────────────────────
SOLANA_TRACKER_API_KEY=
WS_URL=

# Birdeye (OHLCV, token data, WebSocket streaming)
BIRDEYE_API_KEY=41b49e8793df4350aad42f98dd376c43
BIRDEYE_WSS_URL=wss://public-api.birdeye.so/socket/solana?x-api-key=41b49e8793df4350aad42f98dd376c43

# Helius RPC
HELIUS_API_KEY=1771237b-e3a5-49cb-b190-af95b2113788

# ── AI providers ───────────────────────────────────────────────────────────────
# Together powers vector embeddings/search.
TOGETHER_API_KEY=
# OpenAI is used for moderation, summaries, and eval flows.
OPENAI_API_KEY=

# ── Optional wallet vault backend ──────────────────────────────────────────────
VITE_WALLET_API_URL=
VITE_WALLET_API_KEY=

# ── Optional embedded live chess service ──────────────────────────────────────
# e.g. https://chess.solanaos.net
VITE_LIVE_CHESS_URL=

# ── Optional build metadata ────────────────────────────────────────────────────
# Defaults to current git short SHA when omitted
VITE_APP_BUILD_SHA=
