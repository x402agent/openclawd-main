{
  "name": "nanohub",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "bun run generate:solanaos-catalog && bun --bun vite build",
    "build:netlify": "bun run generate:solanaos-catalog && NITRO_PRESET=netlify node ./node_modules/vite/bin/vite.js build && printf '/assets/*  /assets/:splat  200!\\n/clawd-logo.png  /clawd-logo.png  200!\\n/clawd-mark.png  /clawd-mark.png  200!\\n/favicon.ico  /favicon.ico  200!\\n/manifest.json  /manifest.json  200!\\n/og.png  /og.png  200!\\n/og.svg  /og.svg  200!\\n/robots.txt  /robots.txt  200!\\n/webhook  /.netlify/functions/webhook  200!\\n/webhook/*  /.netlify/functions/webhook  200!\\n/*  /.netlify/functions/server  200\\n' > dist/_redirects",
    "check:peers": "bun scripts/check-peer-deps.ts",
    "convex:deploy": "bunx convex deploy --typecheck=disable --yes",
    "deploy:prep": "bun scripts/set-vercel-rewrite.mjs",
    "deploy:prod": "bash scripts/deploy-prod.sh",
    "coverage": "vitest run --coverage",
    "dev": "bun run generate:solanaos-catalog && bun --bun vite dev --port 3000",
    "docs:list": "bun scripts/docs-list.ts",
    "format": "oxfmt --write",
    "lint": "bun run lint:oxlint",
    "lint:fix": "oxlint --type-aware --tsconfig ./tsconfig.oxlint.json ./src ./convex ./packages/clawdhub/src ./packages/schema/src --fix && bun run format",
    "lint:oxlint": "oxlint --type-aware --tsconfig ./tsconfig.oxlint.json ./src ./convex ./packages/clawdhub/src ./packages/schema/src",
    "preinstall": "bunx only-allow bun",
    "preview": "bun --bun vite preview",
    "generate:solanaos-catalog": "bun scripts/generate-solanaos-catalog.mjs",
    "test": "vitest run",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "test:e2e:local": "bash scripts/run-playwright-local.sh",
    "test:pw": "playwright test",
    "test:watch": "vitest",
    "verify:convex-contract": "bun scripts/verify-convex-contract.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "netlify dev:exec drizzle-kit migrate",
    "db:studio": "netlify dev:exec drizzle-kit studio"
  },
  "dependencies": {
    "8004-solana": "^0.8.3",
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.90",
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/manrope": "^5.2.8",
    "@metaplex-foundation/mpl-agent-registry": "^0.2.1",
    "@metaplex-foundation/mpl-core": "^1.8.0",
    "@metaplex-foundation/mpl-toolbox": "^0.10.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@metaplex-foundation/umi-bundle-defaults": "^1.5.1",
    "@metaplex-foundation/umi-web3js-adapters": "^1.5.1",
    "@monaco-editor/react": "^4.7.0",
    "@phantom/react-sdk": "^1.0.7",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@resvg/resvg-wasm": "^2.6.2",
    "@sentry/browser": "^10.49.0",
    "@sentry/node": "^10.49.0",
    "@solana-mobile/wallet-standard-mobile": "^0.5.0",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.9.4",
    "@tanstack/react-router": "^1.157.18",
    "@tanstack/react-router-devtools": "^1.157.18",
    "@tanstack/react-start": "^1.157.18",
    "@tanstack/router-plugin": "^1.157.18",
    "@vercel/analytics": "^1.6.1",
    "bs58": "^6.0.0",
    "clsx": "^2.1.1",
    "convex": "^1.32.0",
    "convex-helpers": "^0.1.114",
    "fflate": "^0.8.2",
    "h3": "^2.0.1-rc.19",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.563.0",
    "monaco-editor": "^0.55.1",
    "nitro": "3.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "semver": "^7.7.3",
    "solanaos-hub-schema": "workspace:*",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "vite-tsconfig-paths": "^6.0.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tanstack/devtools-vite": "^0.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.0.0",
    "only-allow": "^1.2.2",
    "oxfmt": "0.32.0",
    "oxlint": "^1.42.0",
    "oxlint-tsgolint": "^0.11.4",
    "typescript": "^5.9.3",
    "undici": "^7.19.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}