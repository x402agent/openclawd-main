{
  "name": "@openclawdsolana/clawd-tui",
  "version": "0.1.0",
  "description": "OpenClawd TUI — a lobster-themed agent terminal built on @openrouter/agent with OAuth login.",
  "type": "module",
  "bin": {
    "clawd-tui": "dist/cli.js",
    "clawd": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx --env-file-if-exists=.env src/cli.ts",
    "dev": "tsx watch --env-file-if-exists=.env src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "tui",
    "openrouter",
    "cli",
    "clawd",
    "openclawd",
    "solana",
    "lobster"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/x402agent/openclawd.git",
    "directory": "clawd-tui"
  },
  "homepage": "https://github.com/x402agent/openclawd/tree/main/clawd-tui#readme",
  "dependencies": {
    "@openrouter/agent": "latest",
    "@openrouter/sdk": "^0.12.21",
    "glob": "^10.3.10",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
