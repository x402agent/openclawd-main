# CLAWD Cloud OS Environment Configuration
# Copy to .env and fill in your values

# ==================== CORE KEYS ====================
# These three are the minimum useful setup

# xAI API key for Grok-powered agents
XAI_API_KEY=your_xai_api_key_here

# Helius API key for Solana RPC and DAS
HELIUS_API_KEY=your_helius_api_key_here

# SolanaTracker API key for token data and charts
SOLANA_TRACKER_API_KEY=your_solana_tracker_api_key_here

# ==================== SOLANA CONFIG ====================
# Solana network configuration
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=${HELIUS_API_KEY}
SOLANA_NETWORK=mainnet-beta

# Wallet configuration (optional)
# SOLANA_PRIVATE_KEY=your_wallet_private_key_here
# SOLANA_PUBLIC_KEY=your_wallet_public_key_here

# ==================== TELEGRAM CONFIG ====================
# Optional: For Telegram bot integration
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ==================== ADDITIONAL APIS ====================
# Optional: Additional API keys for extended functionality

# OpenAI API key (for fallback models)
# OPENAI_API_KEY=your_openai_api_key_here

# Birdeye API key (for additional market data)
# BIRDEYE_API_KEY=your_birdeye_api_key_here

# Jupiter API key (for swap aggregation)
# JUPITER_API_KEY=your_jupiter_api_key_here

# Firecrawl API key (for web scraping)
# FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# ==================== CLAWD CLOUD CONFIG ====================
# Configuration for solanaclawd.com connection
CLAWD_API_ENDPOINT=https://solanaclawd.com/api
CLAWD_WS_ENDPOINT=wss://solanaclawd.com/ws

# Agent configuration
CLAWD_AGENT_NAME=solana-clawd
CLAWD_AGENT_VERSION=1.0

# ==================== MEMORY PROVIDER ====================
# Memory provider configuration
MEMORY_PROVIDER=honcho-v3
# HONCHO_API_KEY=your_honcho_api_key_here
# HONCHO_BASE_URL=https://api.honcho.io

# ==================== DEVELOPMENT ====================
# Development settings
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ==================== SECURITY ====================
# Security settings
ENABLE_PERMISSIONS=true
DEFAULT_TRADE_PERMISSION=ask
DEFAULT_SIGN_PERMISSION=deny
DEFAULT_SPEND_PERMISSION=deny