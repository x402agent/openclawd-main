# 🐾 OpenClawd API Registrar Environment Variables

# Database (PostgreSQL/Neon)
DATABASE_URL=postgresql://user:password@host:5432/solanaclawd

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS
CORS_ORIGIN=http://localhost:5173

# X (Twitter) API for tweet verification
X_API_BEARER_TOKEN=your_x_api_bearer_token

# Internal secret for ClawdRouter validation
CLAWDROUTER_INTERNAL_SECRET=your_internal_secret_here

# ─── OpenClawd Ecosystem ───────────────────────────────────────────────
# These are shared across the OpenClawd stack
CLAWDROUTER_BASE_URL=https://api.solanaclawd.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
