{
  "name": "@openclawd/clawdrouter",
  "version": "0.1.0",
  "description": "The LLM router built for autonomous Solana agents — Solana-native, wallet-signed, USDC micropayments",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "clawdrouter": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test tests/*.test.ts",
    "doctor": "tsx src/index.ts doctor",
    "clean": "rm -rf dist",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:tail": "wrangler tail",
    "worker:types": "wrangler types"
  },
  "keywords": [
    "solana",
    "llm",
    "router",
    "ai",
    "agent",
    "x402",
    "usdc",
    "claude",
    "grok",
    "openai"
  ],
  "author": "x402agent",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/x402agent/solana-clawd.git",
    "directory": "clawdrouter"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250419.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.15.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
