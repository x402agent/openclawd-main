{
  "name": "clawd-code-cli",
  "version": "1.0.0",
  "description": "🦞 Clawd Code CLI - A lobster-themed AI agent CLI with Solana blockchain integration. ASCII art terminal interface for Solana devs.",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "clawd": "dist/index.js",
    "claw": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:bun": "bun run tsc",
    "dev": "bun run build && node dist/index.js",
    "dev:tsx": "tsx src/index.ts",
    "start": "node dist/index.js",
    "start:bun": "bun run dist/index.js",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "install:bun": "bun install"
  },
  "keywords": [
    "clawd",
    "clawd-code",
    "lobster",
    "cli",
    "agent",
    "text-editor",
    "ai",
    "solana",
    "blockchain",
    "nft",
    "crypto",
    "terminal",
    "ascii",
    "art",
    "ai-assistant"
  ],
  "author": "8bit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/8bit/clawd-code-cli.git"
  },
  "bugs": {
    "url": "https://github.com/8bit/clawd-code-cli/issues"
  },
  "homepage": "https://github.com/8bit/clawd-code-cli",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "axios": "^1.7.0",
    "cfonts": "^3.3.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "enquirer": "^2.4.1",
    "fs-extra": "^11.2.0",
    "ink": "^4.4.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^5.10.1",
    "react": "^18.3.1",
    "ripgrep-node": "^1.0.0",
    "tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.2",
    "@types/node": "^20.8.0",
    "@types/react": "^18.3.3",
    "@typescript-eslint/eslint-plugin": "^8.37.0",
    "@typescript-eslint/parser": "^8.37.0",
    "eslint": "^9.31.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.3",
    "wrangler": "^4.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "preferGlobal": true
}
