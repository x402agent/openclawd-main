# --- LLM provider (xAI / Grok) ---
# XAI_* is the official name; GROK_* is the legacy alias. Either works.
XAI_API_KEY=
XAI_BASE_URL=
XAI_MODEL=grok-code-fast-1
# Legacy aliases (still supported, prefer XAI_*):
GROK_API_KEY=
GROK_BASE_URL=
GROK_MODEL=

# --- OpenRouter (optional, multi-provider routing) ---
OPENROUTER_API_KEY=
# Pre-load OpenRouter models into the /models picker. OPENROUTER_MODEL1 also
# becomes the default model when no XAI_API_KEY is configured.
OPENROUTER_MODEL1=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL2=deepseek/deepseek-v3.2
# OpenRouter passes `reasoning: { enabled: true }` for any openrouter/* model.
# Set to "false" to disable reasoning passthrough.
OPENROUTER_REASONING=true

# --- Solana data (Helius + Birdeye) ---
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com
BIRDEYE_API_KEY=

# --- Local signing wallet (DO NOT COMMIT) ---
# Base58 secret key (Phantom export) or JSON array like [1,2,...]
SOLANA_PRIVATE_KEY=
SOLANA_RPC_URL=

# --- DFlow (trading + prediction markets) ---
# Contact hello@dflow.net for an API key
DFLOW_API_KEY=
DFLOW_TRADING_URL=https://quote-api.dflow.net
DFLOW_METADATA_URL=https://dev-prediction-markets-api.dflow.net

# --- Bags.fm (Solana token launch with fee sharing) ---
BAGS_API_KEY=
BAGS_PARTNER_CONFIG_KEY=

# --- Kalshi direct trading (RSA-PSS signed requests) ---
# KALSHI_PRIVATE_KEY is a PEM string; use \n for newlines, or point KALSHI_PRIVATE_KEY_FILE to a file
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY=
KALSHI_PRIVATE_KEY_FILE=
KALSHI_ENV=prod

# --- Optional: Morph Fast Apply for file edits ---
MORPH_API_KEY=
