# OpenClawd Profile — .env
# Scoped secrets for this profile. Do NOT commit to git.

# ── Solana ─────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=
HELIUS_RPC_URL=https://mainnet.helius-rpc.com

# ── Model Router ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=
CLAWDROUTER_DEFAULT_REASONING=xai/grok-4.20-beta
CLAWDROUTER_DEFAULT_LONGCTX=moonshot/kimi-k2.6

# ── Direct Providers ────────────────────────────────────────────────────
XAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=

# ── Wallet / Privy ─────────────────────────────────────────────────────
PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ── Infra ──────────────────────────────────────────────────────────────
E2B_API_KEY=              # cloud sandbox for browser/shell tools

# ── Telegram (optional bot per profile) ───────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ── Profile metadata ───────────────────────────────────────────────────
CLAWD_PROFILE_HOME=       # auto-set by clawd-profile; do not edit