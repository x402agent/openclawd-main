#!/usr/bin/env bash
# clawd-profile — OpenClawd profile manager
# Inspired by Hermes (Nous Research) profile system, adapted for the claw.
#
# A profile is an isolated agent home directory containing:
#   config.yaml   — model/provider/toolsets/terminal settings
#   .env          — profile-scoped secrets
#   CLAWD.md      — personality / operating charter for this claw
#   memories/     — long-term memory store
#   sessions/     — conversation history
#   skills/       — profile-local skills
#   gateway/      — cached gateway state
#
# Profiles live under $OPENCLAWD_HOME (default: ~/.openclawd/profiles).
# Each profile gets a shell alias at ~/.local/bin/<name> that runs
# `clawd -p <name>` so you can invoke agents directly.

set -euo pipefail

OPENCLAWD_HOME="${OPENCLAWD_HOME:-$HOME/.openclawd}"
PROFILES_DIR="$OPENCLAWD_HOME/profiles"
STATE_FILE="$OPENCLAWD_HOME/state.json"
BIN_DIR="${CLAWD_BIN_DIR:-$HOME/.local/bin}"
TEMPLATES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/templates"

# ── colors ────────────────────────────────────────────────────────
if [ -t 1 ]; then
  BOLD=$'\033[1m'; DIM=$'\033[2m'; CR=$'\033[0m'
  LOBSTER=$'\033[38;5;203m'; NEON=$'\033[38;5;118m'
  CYAN=$'\033[38;5;51m'; MAGENTA=$'\033[38;5;201m'
  VIOLET=$'\033[38;5;141m'; GREY=$'\033[38;5;244m'
else
  BOLD=""; DIM=""; CR=""; LOBSTER=""; NEON=""; CYAN=""; MAGENTA=""; VIOLET=""; GREY=""
fi

ok()   { printf "  ${NEON}✓${CR} %s\n" "$*"; }
info() { printf "  ${CYAN}∎${CR} %s\n" "$*"; }
warn() { printf "  ${LOBSTER}!${CR} %s\n" "$*" >&2; }
die()  { printf "  ${LOBSTER}✗${CR} %s\n" "$*" >&2; exit 1; }

# ── helpers ───────────────────────────────────────────────────────
ensure_dirs() {
  mkdir -p "$PROFILES_DIR" "$BIN_DIR"
  [ -f "$STATE_FILE" ] || echo '{"active":"default"}' > "$STATE_FILE"
}

profile_path() { echo "$PROFILES_DIR/$1"; }

active_profile() {
  if [ -f "$STATE_FILE" ]; then
    grep -o '"active":"[^"]*"' "$STATE_FILE" | cut -d'"' -f4
  else
    echo "default"
  fi
}

set_active() {
  mkdir -p "$(dirname "$STATE_FILE")"
  printf '{"active":"%s"}\n' "$1" > "$STATE_FILE"
}

write_alias() {
  local name="$1"
  local wrapper="$BIN_DIR/$name"
  cat > "$wrapper" <<EOF
#!/usr/bin/env bash
# auto-generated by clawd-profile — launches the '$name' claw
exec clawd -p "$name" "\$@"
EOF
  chmod +x "$wrapper"
}

scaffold_profile() {
  local name="$1"
  local dir; dir="$(profile_path "$name")"
  [ -e "$dir" ] && die "profile '$name' already exists at $dir"

  mkdir -p "$dir"/{memories,sessions,skills,gateway}

  if [ -f "$TEMPLATES_DIR/config.yaml" ]; then
    sed "s/{{NAME}}/$name/g" "$TEMPLATES_DIR/config.yaml" > "$dir/config.yaml"
  else
    cat > "$dir/config.yaml" <<EOF
name: $name
model: xai/grok-4.20-beta
provider: clawdrouter
EOF
  fi

  if [ -f "$TEMPLATES_DIR/CLAWD.md" ]; then
    sed "s/{{NAME}}/$name/g" "$TEMPLATES_DIR/CLAWD.md" > "$dir/CLAWD.md"
  fi

  if [ -f "$TEMPLATES_DIR/.env.example" ]; then
    cp "$TEMPLATES_DIR/.env.example" "$dir/.env"
  else
    : > "$dir/.env"
  fi

  echo "$dir"
}

# ── commands ──────────────────────────────────────────────────────
cmd_create() {
  local name="${1:-}"; [ -z "$name" ] && die "usage: clawd profile create <name>"
  ensure_dirs
  local dir; dir="$(scaffold_profile "$name")"
  write_alias "$name"
  ok "created profile ${BOLD}${LOBSTER}$name${CR} at ${DIM}$dir${CR}"
  ok "alias installed: ${VIOLET}$BIN_DIR/$name${CR}"
  info "edit ${CYAN}$dir/CLAWD.md${CR} to shape this claw's personality"
}

cmd_list() {
  ensure_dirs
  local active; active="$(active_profile)"
  printf "\n  ${BOLD}${CYAN}openclawd profiles${CR}  ${DIM}($PROFILES_DIR)${CR}\n\n"
  local found=0
  for d in "$PROFILES_DIR"/*/; do
    [ -d "$d" ] || continue
    local n; n="$(basename "$d")"
    if [ "$n" = "$active" ]; then
      printf "    ${NEON}●${CR} ${BOLD}%s${CR}  ${DIM}(active)${CR}\n" "$n"
    else
      printf "    ${GREY}○${CR} %s\n" "$n"
    fi
    found=1
  done
  [ "$found" -eq 0 ] && printf "    ${DIM}(no profiles yet — run: clawd profile create default)${CR}\n"
  printf "\n"
}

cmd_show() {
  local name="${1:-$(active_profile)}"
  local dir; dir="$(profile_path "$name")"
  [ -d "$dir" ] || die "profile '$name' not found"
  printf "\n  ${BOLD}${LOBSTER}$name${CR}  ${DIM}$dir${CR}\n\n"
  [ -f "$dir/config.yaml" ] && { printf "  ${CYAN}config.yaml${CR}\n"; sed 's/^/    /' "$dir/config.yaml"; echo; }
  [ -f "$dir/CLAW.md" ]     && { printf "  ${CYAN}CLAW.md${CR}    ${DIM}($(wc -l < "$dir/CLAW.md") lines)${CR}\n"; }
  [ -d "$dir/sessions" ]    && printf "  ${CYAN}sessions${CR}   ${DIM}$(find "$dir/sessions" -type f 2>/dev/null | wc -l | tr -d ' ') files${CR}\n"
  [ -d "$dir/memories" ]    && printf "  ${CYAN}memories${CR}   ${DIM}$(find "$dir/memories" -type f 2>/dev/null | wc -l | tr -d ' ') files${CR}\n"
  echo
}

cmd_use() {
  local name="${1:-}"; [ -z "$name" ] && die "usage: clawd profile use <name>"
  [ -d "$(profile_path "$name")" ] || die "profile '$name' not found"
  ensure_dirs
  set_active "$name"
  ok "active profile is now ${BOLD}${LOBSTER}$name${CR}"
}

cmd_delete() {
  local name="${1:-}"; [ -z "$name" ] && die "usage: clawd profile delete <name>"
  local dir; dir="$(profile_path "$name")"
  [ -d "$dir" ] || die "profile '$name' not found"
  printf "  ${LOBSTER}delete '$name' and all its state? [y/N]${CR} "
  read -r ans
  [ "$ans" = "y" ] || [ "$ans" = "Y" ] || { info "cancelled"; return; }
  rm -rf "$dir"
  rm -f "$BIN_DIR/$name"
  ok "deleted profile '$name'"
}

cmd_rename() {
  local old="${1:-}"; local new="${2:-}"
  [ -z "$old" ] || [ -z "$new" ] && die "usage: clawd profile rename <old> <new>"
  local od; od="$(profile_path "$old")"; local nd; nd="$(profile_path "$new")"
  [ -d "$od" ] || die "profile '$old' not found"
  [ -e "$nd" ] && die "profile '$new' already exists"
  mv "$od" "$nd"
  rm -f "$BIN_DIR/$old"
  write_alias "$new"
  [ "$(active_profile)" = "$old" ] && set_active "$new"
  ok "renamed $old → $new"
}

cmd_clone() {
  local src="${1:-}"; local dst="${2:-}"
  [ -z "$src" ] || [ -z "$dst" ] && die "usage: clawd profile clone <src> <dst>"
  local sd; sd="$(profile_path "$src")"; local dd; dd="$(profile_path "$dst")"
  [ -d "$sd" ] || die "profile '$src' not found"
  [ -e "$dd" ] && die "profile '$dst' already exists"
  cp -R "$sd" "$dd"
  write_alias "$dst"
  ok "cloned $src → $dst"
}

cmd_export() {
  local name="${1:-}"; local out="${2:-$name.tar.gz}"
  [ -z "$name" ] && die "usage: clawd profile export <name> [out.tar.gz]"
  local dir; dir="$(profile_path "$name")"
  [ -d "$dir" ] || die "profile '$name' not found"
  tar -czf "$out" -C "$PROFILES_DIR" "$name"
  ok "exported to $out"
}

cmd_import() {
  local archive="${1:-}"
  [ -z "$archive" ] || [ ! -f "$archive" ] && die "usage: clawd profile import <archive.tar.gz>"
  ensure_dirs
  tar -xzf "$archive" -C "$PROFILES_DIR"
  local n; n="$(tar -tzf "$archive" | head -1 | cut -d/ -f1)"
  write_alias "$n"
  ok "imported profile '$n'"
}

cmd_path() {
  local name="${1:-$(active_profile)}"
  echo "$(profile_path "$name")"
}

usage() {
  cat <<EOF
${BOLD}${LOBSTER}clawd-profile${CR} — manage OpenClawd agent profiles

${BOLD}USAGE${CR}
  clawd profile <command> [args]

${BOLD}COMMANDS${CR}
  ${CYAN}create${CR}  <name>           scaffold a new profile + CLI alias
  ${CYAN}list${CR}                     list profiles (active marked ●)
  ${CYAN}show${CR}    [name]           inspect a profile
  ${CYAN}use${CR}     <name>           set active (sticky) profile
  ${CYAN}rename${CR}  <old> <new>      rename a profile
  ${CYAN}clone${CR}   <src> <dst>      duplicate a profile
  ${CYAN}delete${CR}  <name>           remove a profile (prompts)
  ${CYAN}export${CR}  <name> [file]    tar.gz a profile
  ${CYAN}import${CR}  <archive>        restore a profile
  ${CYAN}path${CR}    [name]           print profile directory

${BOLD}ENV${CR}
  OPENCLAWD_HOME   root state dir   ${DIM}(default: ~/.openclawd)${CR}
  CLAWD_BIN_DIR    alias dir        ${DIM}(default: ~/.local/bin)${CR}
EOF
}

main() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    create) cmd_create "$@" ;;
    list|ls) cmd_list "$@" ;;
    show|info) cmd_show "$@" ;;
    use|switch) cmd_use "$@" ;;
    delete|rm|remove) cmd_delete "$@" ;;
    rename|mv) cmd_rename "$@" ;;
    clone|cp) cmd_clone "$@" ;;
    export) cmd_export "$@" ;;
    import) cmd_import "$@" ;;
    path|where) cmd_path "$@" ;;
    ""|-h|--help|help) usage ;;
    *) usage; exit 1 ;;
  esac
}

main "$@"
