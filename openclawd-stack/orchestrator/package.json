{
  "name": "@openclawd/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx --watch index.ts",
    "start": "tsx index.ts",
    "build": "tsc -p .",
    "build:all": "pnpm --filter @solana-clawd/privy-agentic-wallet build && pnpm --filter @solana-clawd/solana-clawd-mcp build && pnpm build",
    "smoke:integration": "tsx smoke-integration.ts"
  },
  "dependencies": {
    "@honcho-ai/sdk": "^1.6.0",
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@solana-clawd/privy-agentic-wallet": "workspace:*",
    "@solana-clawd/solana-clawd-mcp": "workspace:*",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "e2b": "^1.5.0",
    "hono": "^4.6.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
