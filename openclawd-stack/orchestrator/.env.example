# openclawd orchestrator — copy to .env and fill in
ORCHESTRATOR_PORT=8787
# Comma-separated origins allowed by CORS. Keep prod + localhost dev here.
ORCHESTRATOR_CORS_ORIGINS=https://solanaclawd.com,https://www.solanaclawd.com,http://localhost:3000,http://localhost:5173

# E2B sandbox runtime
E2B_API_KEY=

# Privy auth (required — fronts all /v1/* routes)
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_CLIENT_ID=
PRIVY_JWKS_ENDPOINT=
PRIVY_AUTH_KEY_ID=
PRIVY_AUTH_PRIVATE_KEY=
PRIVY_PUBLIC_KEY=

# Honcho memory — supports 2 webhook endpoints
HONCHO_URL=https://api.honcho.dev
HONCHO_API_KEY=
HONCHO_WEBHOOK_SECRET=
HONCHO_WEBHOOK_URL1=https://solanaclawd.com/webhook/
HONCHO_WEBHOOK_URL2=https://solanaclawd.com/webhook/chat
HONCHO_WEBHOOKSECRET2=
HONCHO_WORKSPACE_ID=pumpfun

# Forwarded to each sandbox as OPENAI_API_KEY by sandbox-manager.#buildEnvs
OPENAI_API_KEY_FALLBACK=
ANTHROPIC_API_KEY_FALLBACK=

# Data provider fallbacks for the sandbox tool bridge (helius / solana-tracker)
HELIUS_RPC=
HELIUS_API_KEY=
HELIUS_RPC_FALLBACK=
SOLANA_TRACKER_KEY_FALLBACK=

# Solana Clawd MCP — forwarded to each spawned MCP child process
XAI_API_KEY=

# Payments (ClawdRouter / clawd-vault on-chain registry)
ORCHESTRATOR_KEEPER_KEY=
CLAWD_VAULT_PROGRAM=
CLAWD_REGISTRY_SEED=clawd-registry-v1
PINATA_JWT=
GATEWAY_ORIGIN=https://solanaclawd.com
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Telegram channel
TELEGRAM_ALLOW_CHAT_IDS=-1003338091119
