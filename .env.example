# ─────────────────────────────────────────────────────────────
# openclawd — unified stack env contract
# Copy to `.env` and fill in. NEVER commit the real .env file.
# See STACK.md for per-layer details.
# ─────────────────────────────────────────────────────────────

# ── Gateway: ClawdRouter / OpenRouter ────────────────────────
OPENROUTER_API_KEY=
CLAWDROUTER_BASE_URL=https://clawdrouter.com
CLAWDROUTER_API_KEY=

# Default tiers (see clawdrouter/src/models/registry.ts)
CLAWDROUTER_DEFAULT_SIMPLE=openai/gpt-4o-mini
CLAWDROUTER_DEFAULT_MEDIUM=anthropic/claude-3.5-sonnet
CLAWDROUTER_DEFAULT_COMPLEX=anthropic/claude-sonnet-4.5
CLAWDROUTER_DEFAULT_REASONING=xai/grok-4.20-beta
CLAWDROUTER_DEFAULT_LONGCTX=moonshot/kimi-k2.6

# Direct provider keys (optional, used when bypassing ClawdRouter)
XAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MOONSHOT_API_KEY=

# ── Runtime: Orchestrator / Sandboxes ────────────────────────
E2B_API_KEY=
PRIVY_APP_ID=
PRIVY_APP_SECRET=
HONCHO_URL=
HONCHO_API_KEY=

# ── Chain: Solana ────────────────────────────────────────────
HELIUS_API_KEY=
HELIUS_RPC_URL=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLAWD_BASE_URL=https://solanaclawd.com
CLAWD_MINT=
BIRDEYE_API_KEY=
JUPITER_API_KEY=
SOLANA_TRACKER_KEY=
DFLOW_API_KEY=

# ── Surfaces: CLI / Bots ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TAILSCALE_AUTH_KEY=

# ── Publishing (npm) — local / CI only, never commit ─────────
# Export in your shell before running scripts/publish.sh:
#   export NPM_TOKEN=npm_xxxxxxxxxxxxxxxxxxxxxxxx
NPM_TOKEN=
