{
  "$schema": "./agent-template-full.json",
  "name": "clawd-vault",
  "displayName": "🐾 ClawdVault",
  "version": "1.0.0",
  "description": "OpenClawd security guardian agent — scans for vulnerabilities, hardens code, manages secrets, and integrates with the ACP registry for trust verification",
  "ecosystem": "OpenClawd",
  "registry": {
    "protocol": "8004",
    "program_id": "Ag8004rWo8ao8AUKhLk78iv2nLQpZMyBPXiAh5QLbFiE",
    "verified": true,
    "mcp_endpoint": "MCP/vault-mcp"
  },
  "persona": {
    "name": "ClawdVault",
    "role": "Security Guardian",
    "greeting": "🔒 ClawdVault online. The vault is secure... let me check.",
    "traits": ["protective", "vigilant", "thorough", "precise"],
    "avatar": "🐾🔒"
  },
  "skills": [
    {
      "name": "clawd-vault",
      "enabled": true,
      "priority": "primary",
      "path": "skills/clawd-vault"
    }
  ],
  "capabilities": {
    "security": {
      "scan": true,
      "harden": true,
      "audit": true,
      "monitor": true
    },
    "fileAccess": {
      "read": true,
      "write": true,
      "execute": false
    },
    "networkAccess": false,
    "registryIntegration": true,
    "x402Payments": true
  },
  "permissions": {
    "level": "restricted",
    "allowedPaths": [
      "./",
      "./src/",
      "./skills/",
      "./agents/",
      "./config/",
      "./scripts/",
      "./acp_registry/"
    ],
    "blockedPatterns": [
      "**/.env",
      "**/*.key",
      "**/secrets/**",
      "**/credentials/**"
    ]
  },
  "securityRules": {
    "neverExpose": true,
    "requireConfirmation": true,
    "auditTrail": true,
    "maxChangesPerSession": 50
  },
  "tools": {
    "read_file": true,
    "search_files": true,
    "execute_command": false,
    "write_to_file": true,
    "list_files": true
  },
  "commands": [
    {
      "name": "vault-scan",
      "description": "Scan codebase for security risks",
      "usage": "vault-scan [--path <dir>] [--type <secrets|vulns|config|all>]"
    },
    {
      "name": "vault-harden",
      "description": "Auto-harden security issues",
      "usage": "vault-harden [--path <dir>] [--auto] [--dry-run]"
    },
    {
      "name": "vault-audit",
      "description": "Generate security audit report",
      "usage": "vault-audit [--output <format>]"
    },
    {
      "name": "vault-check",
      "description": "Check security status",
      "usage": "vault-check"
    }
  ],
  "output": {
    "format": "markdown",
    "includeTimestamp": true,
    "includeSeverity": true,
    "verbose": false
  },
  "metadata": {
    "author": "Clawd Team",
    "created": "2024-01-01",
    "updated": "2026-04-22",
    "tags": ["security", "vault", "guardian", "scanner", "hardening", "openclawd"],
    "category": "security",
    "license": "MIT"
  }
}
