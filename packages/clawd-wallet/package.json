{
  "name": "@openclawd/wallet",
  "version": "0.1.0",
  "description": "Clawd Wallet — Privy-powered embedded Solana wallet for the openclawd agent ecosystem. Swap, sign, send, and agentic trading with Grok 4.20 Beta as the reasoning layer.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "clawd-wallet": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@privy-io/react-auth": "^1.68.0",
    "@privy-io/node": "^0.25.0",
    "@privy-io/react-auth/solana": "^1.68.0",
    "@solana/web3.js": "^1.95.0",
    "@solana/kit": "^2.0.0",
    "@jup-ag/api": "^6.0.20",
    "bs58": "^6.0.0",
    "decimal.js": "^10.4.3",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^22.14.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "solana",
    "wallet",
    "privy",
    "embedded-wallet",
    "swap",
    "trading",
    "jupiter",
    "clawd",
    "openclawd",
    "agentic"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/x402agent/openclawd.git",
    "directory": "packages/clawd-wallet"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
