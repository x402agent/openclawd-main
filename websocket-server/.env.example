# PumpFun WebSocket Relay Server — Environment Variables

# ── Server ────────────────────────────────────────────────────────────────────
# Port for the HTTP + WebSocket server (browsers connect here)
PORT=3099

# ── Solana RPC ────────────────────────────────────────────────────────────────
# HTTP RPC endpoint (used by ClaimMonitor for transaction fetching)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# WebSocket RPC endpoint (used by SolanaMonitor for log subscriptions)
# Recommended: use a paid RPC (Helius, QuickNode, Triton) for reliable WS
SOLANA_RPC_WS=wss://api.mainnet-beta.solana.com
# SOLANA_RPC_WS=wss://atlas-mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Preferred Helius aliases. When set, the relay uses these ahead of SOLANA_RPC_*.
# For Fly production, set these with:
#   HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=...
#   HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=...
# and register the webhook URL:
#   https://clawd-ws.fly.dev/webhook/helius
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=REPLACE_ME
HELIUS_WSS_URL=wss://mainnet.helius-rpc.com/?api-key=REPLACE_ME

# ── Claim Monitor ─────────────────────────────────────────────────────────────
# Enable on-chain fee claim detection (default: true)
ENABLE_CLAIMS=true

# How often to poll for new claim transactions in milliseconds (default: 15000)
CLAIM_POLL_INTERVAL=15000

# ── dFlow (DEX aggregator + Kalshi prediction markets on Solana) ──────────────
# Server-side API key — kept out of the browser. If unset, routes still work
# but dFlow may rate-limit or reject unauthenticated traffic.
DFLOW_API_KEY=
DFLOW_QUOTE_API_URL=https://d.quote-api.dflow.net
DFLOW_MARKETS_API_URL=https://d.prediction-markets-api.dflow.net

# ── Helius (enhanced webhooks + Parse API) ────────────────────────────────────
# Register a webhook at https://dashboard.helius.dev pointing to:
#   https://clawd-ws.fly.dev/webhook/helius
# Set HELIUS_WEBHOOK_AUTH to the same secret so the relay rejects spoofed POSTs.
HELIUS_API_KEY=
HELIUS_ATLAS_WSS_URL=wss://atlas-mainnet.helius-rpc.com/?api-key=REPLACE_ME
HELIUS_PARSE_URL=
HELIUS_WEBHOOK_AUTH=clawd_wh_replace_me
HELIUS_NETWORK=mainnet
