{
  "name": "openclawd",
  "description": "The complete open-source stack for building, deploying, and monetizing AI agents on Solana. One router · one settlement layer · 33 projects · 50 agents · 100 skills.",
  "version": "1.0.0",
  "type": "https://eips.ethereum.org/EIPS/eip-8004#registration-v1",
  "services": [
    {
      "name": "dashboard",
      "endpoint": "https://solanaclawd.com",
      "description": "Main dashboard — agent discovery, skills marketplace, x402 gateway"
    },
    {
      "name": "api",
      "endpoint": "https://solanaclawd.com/api",
      "description": "REST API for skills, agents, registry"
    },
    {
      "name": "marketplace",
      "endpoint": "https://solanaclawd.com/marketplace",
      "description": "ClawdHub skills marketplace — 100 SKILL.md files"
    },
    {
      "name": "mcp",
      "endpoint": "https://solanaclawd.com/mcp",
      "description": "Model Context Protocol server"
    }
  ],
  "capabilities": {
    "solana": {
      "enabled": true,
      "rpcUrl": "${SOLANA_RPC_URL}",
      "walletSupport": true
    },
    "mcp": {
      "enabled": true,
      "tools": [
        "helius-das",
        "helius-rpc",
        "jupiter-price",
        "jupiter-swap",
        "jupiter-limit-order",
        "solana-pay",
        "tensor",
        "birdeye-price",
        "metaplex-core",
        "firecrawl"
      ]
    },
    "payment": {
      "enabled": true,
      "protocols": ["x402", "MPP", "AP2", "A2A"],
      "tokens": ["USDC", "CLAWD"]
    }
  },
  "models": {
    "default": "xai/grok-4.20-beta",
    "agents": {
      "reasoning": "xai/grok-4.20-beta",
      "longctx": "moonshot/kimi-k2.6",
      "eco": "nvidia/gpt-oss-120b",
      "premium": "anthropic/claude-opus-4.6"
    }
  },
  "memory": {
    "provider": "honcho",
    "tiers": {
      "KNOWN": { "expiry": false, "persistence": "persistent" },
      "LEARNED": { "expiry": false, "persistence": "persistent" },
      "INFERRED": { "expiry": true, "persistence": "ephemeral" }
    }
  },
  "principles": [
    "KNOWN before INFERRED — never present speculation as fact",
    "Preserve capital first — drawdown cascades override all conviction",
    "Deny-first permissions — ask before executing anything irreversible",
    "Transparency — show reasoning, not just conclusions",
    "Local-first — no mandatory cloud infrastructure"
  ],
  "permissions": {
    "defaults": {
      "trade": "ask",
      "sign": "deny",
      "spend": "deny",
      "transfer": "ask"
    }
  }
}